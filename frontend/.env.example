# ──────────────────────────────────────────────────────────────────────────
# fitlo — single Next.js app environment (native dev).
# The app serves both the UI and /api/* Route Handlers, so there is one env.
# For native dev:  cp .env.example .env.local  (point at host-published infra)
# Under Docker Compose these come from the root .env / compose env_file.
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# Database (host-published Docker Postgres; remap the port if 5432 is taken)
DATABASE_URL=postgresql://fitcoach:fitcoach_dev_pw@localhost:5432/fitcoach?schema=public

# Object storage (MinIO locally; AWS S3 in prod — same code path)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_AVATARS=avatars
S3_BUCKET_GIFS=gifs
S3_BUCKET_PDFS=pdfs
S3_BUCKET_REQUESTS=requests

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Auth / OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
EMAIL_FROM=no-reply@fitlo.local

# Payments (blank → in-app simulate checkout)
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PDF (Puppeteer). On a host without Chromium here, PDF degrades to a clean 503.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# App URL / cookies
APP_PUBLIC_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
