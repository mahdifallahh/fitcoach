# ──────────────────────────────────────────────────────────────────────────
# Frontend (Next.js) environment.
# For native dev:  cp .env.example .env.local
# Under Docker Compose these come from the root .env / compose env_file.
# ──────────────────────────────────────────────────────────────────────────

# Browser-facing API base (host-mapped backend port)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side (RSC / route handlers) API base.
# Native dev: http://localhost:4000 ; Docker: http://backend:4000
BACKEND_INTERNAL_URL=http://localhost:4000
