# ──────────────────────────────────────────────────────────────────────────
# Backend (NestJS) environment.
# For native dev:  cp .env.example .env  (values point at localhost)
# Under Docker Compose these are supplied by the root .env / compose env_file.
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://fitcoach:fitcoach_dev_pw@localhost:5432/fitcoach?schema=public

# Redis (cache + BullMQ)
REDIS_URL=redis://localhost:6379

# Object storage (MinIO locally; AWS S3 in prod — same code path)
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_AVATARS=avatars
S3_BUCKET_GIFS=gifs
S3_BUCKET_PDFS=pdfs

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Auth / OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@fitcoach.local

# Payments
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App URLs / CORS / cookies
FRONTEND_ORIGIN=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:4000
COOKIE_DOMAIN=localhost
