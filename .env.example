# ──────────────────────────────────────────────────────────────────────────
# Root Docker Compose environment.
# Copy to `.env` (`cp .env.example .env`) before running `docker compose up`.
# These values are consumed by docker-compose.yml and passed into containers.
# ──────────────────────────────────────────────────────────────────────────

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=fitcoach
POSTGRES_PASSWORD=fitcoach_dev_pw
POSTGRES_DB=fitcoach
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Buckets auto-created by the minio-init service
S3_BUCKET_AVATARS=avatars
S3_BUCKET_GIFS=gifs
S3_BUCKET_PDFS=pdfs
S3_BUCKET_REQUESTS=requests

# ── Backend (NestJS) ─────────────────────────────────────────────────────────
BACKEND_PORT=4000
# Inside the compose network services resolve each other by service name.
DATABASE_URL=postgresql://fitcoach:fitcoach_dev_pw@postgres:5432/fitcoach?schema=public
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
# Public endpoint browsers use to fetch/upload objects (host-mapped MinIO port)
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# JWT secrets — generate strong values for anything beyond local dev
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Auth / OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# Provider selection: "mock" logs codes to console; swap for real impls in prod
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock

# Pluggable provider creds (only needed when provider != mock)
SMS_API_KEY=
SMS_SENDER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@fitcoach.local

# Payments
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS / app URLs
FRONTEND_ORIGIN=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000
# Externally-reachable base URL of the backend (used to build magic links)
BACKEND_PUBLIC_URL=http://localhost:4000
COOKIE_DOMAIN=localhost

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
FRONTEND_PORT=3000
# Server-side calls inside the compose network
BACKEND_INTERNAL_URL=http://backend:4000
# Browser-side calls (host-mapped backend port)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
