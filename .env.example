# fitlo — production environment (Chabokan). کل این فایل را در بخش Environment
# سرویس کپی کن و مقدارهای علامت‌خورده با «پر کن» را کامل کن.

NODE_ENV=production

# ── دامنه / کوکی (باید با دامنهٔ واقعی روی HTTPS یکی باشد وگرنه ورود کار نمی‌کند)
APP_PUBLIC_URL=https://fitlo.ir
NEXT_PUBLIC_SITE_URL=https://fitlo.ir
COOKIE_DOMAIN=fitlo.ir

# ── دیتابیس (Postgres چابکان)
DATABASE_URL=postgresql://postgres:nLEaamtsJVOyYCJb@services.irn4.chabokan.net:61593/fitlo?schema=public

# ── فضای فایل (MinIO) — باکت‌های avatars/gifs/pdfs عمومی، requests خصوصی
S3_ENDPOINT=https://minio.nobivo.ir
S3_PUBLIC_ENDPOINT=https://minio.nobivo.ir
S3_ACCESS_KEY=wxtqRustTlGYV2mk8bfvMoJzGNDiUZyY
S3_SECRET_KEY=oD5fiUN68SRndxfASmEA7561Po0gTFHg
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_AVATARS=avatars
S3_BUCKET_GIFS=gifs
S3_BUCKET_PDFS=pdfs
S3_BUCKET_REQUESTS=requests

# ── نشست‌ها (JWT) — مخفی نگه دار؛ عوض‌کردنشان همه را از حساب خارج می‌کند
JWT_ACCESS_SECRET=Po4uw57-eQB6H1AOyUt2vUlHRsrwLYqBgzb1ubPN5pkWbslYEMTJAEv3s1dWm1iH
JWT_REFRESH_SECRET=3RRQ6SlTHW1dHGCokLVULTVxltQ_jplwJlnyWy65OnTu7UqN980zINnBfb1buA9h
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ── OTP / پیامک (SMS.ir)
OTP_TTL_SECONDS=300
OTP_LENGTH=6
SMS_PROVIDER=smsir
# کلید و قالب هر دو تست شده‌اند (ارسال واقعی + گزارش تحویل موفق).
SMSIR_API_KEY=lDEtbH2GVoqj0y0mUiY0lPBk5yAjpuCKgqq79dD3ngIilRAM
# قالب تأییدشدهٔ «فیتلو»: «رمز یکبار مصرف شما: #CODE#»
SMSIR_TEMPLATE_ID=931379
SMSIR_PARAM_NAME=Code
EMAIL_FROM=no-reply@fitlo.ir

# ── پرداخت (فقط زرین‌پال)
# پر کن: مرچنت‌کد زرین‌پال. تا خالی باشد پرداخت در حالت شبیه‌سازی می‌ماند.
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=false

# ── ادمین — ورود با این شماره(ها) دسترسی پنل /admin می‌گیرد (با کاما جدا کن)
ADMIN_PHONES=+989356995806

# ── سئو (اختیاری) — کد تأیید مالکیت Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── PDF — مسیر Chromium روی سرور. اگر روی سرویس چابکان Chromium نصب نیست این را
# خالی/دست‌نخورده بگذار؛ خروجی PDF به‌جای خطای ناجور، پیام «موقتاً در دسترس نیست» می‌دهد.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
