# ──────────────────────────────────────────────────────────────────────────
# Root Docker Compose environment (single fitlo app + Postgres + MinIO).
# Copy to `.env` (`cp .env.example .env`) before running `docker compose up`.
# These values are consumed by docker-compose.yml and passed into the container.
# ──────────────────────────────────────────────────────────────────────────

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=fitcoach
POSTGRES_PASSWORD=fitcoach_dev_pw
POSTGRES_DB=fitcoach
# Host-published port. Remap if 5432 collides with a host-native PostgreSQL.
POSTGRES_PORT=5432

# ── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Buckets auto-created by the minio-init service (requests stays private)
S3_BUCKET_AVATARS=avatars
S3_BUCKET_GIFS=gifs
S3_BUCKET_PDFS=pdfs
S3_BUCKET_REQUESTS=requests

# ── App (Next.js: UI + /api) ─────────────────────────────────────────────────
APP_PORT=3000
# Inside the compose network the app reaches Postgres/MinIO by service name.
DATABASE_URL=postgresql://fitcoach:fitcoach_dev_pw@postgres:5432/fitcoach?schema=public
S3_ENDPOINT=http://minio:9000
# Public endpoint browsers use to fetch/upload objects (host-mapped MinIO port)
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# JWT secrets — generate strong values for anything beyond local dev
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Auth / OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# Provider selection: "mock" logs codes to console; swap for real impls in prod
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@fitlo.local

# Payments (leave blank in dev → in-app "simulate" checkout is used)
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PDF (Puppeteer → system Chromium provided by the app image)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# App URL / cookies (same-origin: the app serves UI + API)
APP_PUBLIC_URL=http://localhost:3000
COOKIE_DOMAIN=localhost

# Canonical public origin for SEO (canonical URLs, sitemap, robots, OG tags).
# Set this to your real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Platform owner phone numbers (comma-separated). Logging in with one of these
# makes the account ADMIN and opens the /admin panel. Set to YOUR phone.
ADMIN_PHONES=+989120000001

# SMS.ir (production OTP). Set SMS_PROVIDER=smsir and fill these; the template
# must be approved in the SMS.ir panel and contain the {Code} parameter.
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=
SMSIR_PARAM_NAME=Code
