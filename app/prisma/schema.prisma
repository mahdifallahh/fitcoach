// FitCoach data model. See docs/data-model.md for the narrative + linking-rule walkthrough.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────
enum Role {
  COACH
  STUDENT
  ADMIN
}

enum OtpChannel {
  SMS
  EMAIL
}

enum OtpPurpose {
  LOGIN
  MAGIC_LINK
}

enum ProgramStatus {
  DRAFT
  PUBLISHED
}

enum SubscriptionPlan {
  M3
  M6
  M12
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  EXPIRED
  CANCELED
}

enum PaymentGateway {
  ZARINPAL
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ProgramRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ── Identity & auth ──────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  phone        String?  @unique
  email        String?  @unique
  role         Role
  locale       String   @default("fa")
  passwordHash String? // scrypt hash; set after first OTP signup, then used for password login
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coachProfile     CoachProfile?
  studentProfiles  StudentProfile[] // a student may be linked to several coaches' profiles
  refreshTokens    RefreshToken[]
  programRequests  ProgramRequest[] // intake requests this user (as student) submitted

  @@index([phone])
  @@index([email])
}

model OtpToken {
  id         String     @id @default(cuid())
  identifier String // normalized phone (E.164) or lowercased email
  channel    OtpChannel
  purpose    OtpPurpose @default(LOGIN)
  codeHash   String // hashed OTP code or magic-link token
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  @@index([identifier])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Coach domain ─────────────────────────────────────────────────────────────
model CoachProfile {
  userId       String   @id
  handle       String?  @unique // public page slug: /c/<handle>
  name         String
  bio          String?
  avatarUrl    String?
  socialLinks  Json     @default("[]") // [{ type, label, url }]
  tags         String[] @default([])
  // Payment details shown on the student intake form (manual card-to-card)
  cardNumber   String?
  cardHolder   String?
  programPrice Int? // Toman
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories       ExerciseCategory[]
  exercises        Exercise[]
  programs         Program[]
  templates        ProgramTemplate[]
  students         StudentProfile[]
  subscriptions    Subscription[]
  payments         Payment[]
  requests         ProgramRequest[]
}

model ExerciseCategory {
  id        String   @id @default(cuid())
  coachId   String
  name      String
  createdAt DateTime @default(now())

  coach     CoachProfile @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  exercises Exercise[]

  @@unique([coachId, name])
  @@index([coachId])
}

model Exercise {
  id          String   @id @default(cuid())
  coachId     String
  categoryId  String?
  name        String
  defaultSets Int      @default(3)
  defaultReps String   @default("10") // free text: "10", "8-12", "to failure"
  description String?
  gifUrl      String?
  videoUrl    String? // optional demo video link (YouTube / Aparat / any)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach             CoachProfile      @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  category          ExerciseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  programExercises  ProgramExercise[]
  templateExercises TemplateExercise[]

  @@index([coachId, categoryId])
  @@index([coachId])
}

// ── Student (linking pivot) ──────────────────────────────────────────────────
model StudentProfile {
  id        String   @id @default(cuid())
  userId    String? // null until the student registers and claims this profile
  coachId   String
  phone     String? // normalized E.164
  email     String? // lowercased
  age       Int?
  heightCm  Float?
  weightKg  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  coach    CoachProfile @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  programs Program[]

  @@unique([coachId, phone])
  @@unique([coachId, email])
  @@index([phone])
  @@index([email])
  @@index([userId])
}

// ── Programs ─────────────────────────────────────────────────────────────────
model Program {
  id               String        @id @default(cuid())
  coachId          String
  studentProfileId String
  name             String
  daysPerWeek      Int
  status           ProgramStatus @default(DRAFT)
  // snapshots of student stats at authoring time
  studentAge       Int?
  studentHeightCm  Float?
  studentWeightKg  Float?
  pdfUrl           String?
  pdfStaleAt       DateTime? // set when the program changes; clears after regen
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  coach   CoachProfile   @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  days    ProgramDay[]

  @@index([coachId])
  @@index([studentProfileId])
}

model ProgramDay {
  id        String @id @default(cuid())
  programId String
  dayIndex  Int
  title     String?

  program   Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]

  @@unique([programId, dayIndex])
  @@index([programId])
}

model ProgramExercise {
  id             String  @id @default(cuid())
  programDayId   String
  exerciseId     String
  sets           Int
  reps           String
  notes          String?
  order          Int // sequence within the day (items & superset groups)
  supersetGroupId String? // shared id => same superset
  supersetOrder  Int? // sequence within the superset group

  day      ProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exercise Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([programDayId])
  @@index([exerciseId])
  @@index([supersetGroupId])
}

// ── Program templates (reusable, student-agnostic) ───────────────────────────
// A coach authors a template once (e.g. "Beginner full-body"), then assigns it
// to any student — which materializes a real Program. Same day/superset shape as
// Program, minus the student and snapshot fields.
model ProgramTemplate {
  id          String   @id @default(cuid())
  coachId     String
  name        String
  description String?
  daysPerWeek Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coach CoachProfile  @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  days  TemplateDay[]

  @@index([coachId])
}

model TemplateDay {
  id         String  @id @default(cuid())
  templateId String
  dayIndex   Int
  title      String?

  template  ProgramTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercises TemplateExercise[]

  @@unique([templateId, dayIndex])
  @@index([templateId])
}

model TemplateExercise {
  id              String  @id @default(cuid())
  templateDayId   String
  exerciseId      String
  sets            Int
  reps            String
  notes           String?
  order           Int
  supersetGroupId String?
  supersetOrder   Int?

  day      TemplateDay @relation(fields: [templateDayId], references: [id], onDelete: Cascade)
  exercise Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([templateDayId])
  @@index([exerciseId])
  @@index([supersetGroupId])
}

// ── Subscriptions & payments ─────────────────────────────────────────────────
model Subscription {
  id        String             @id @default(cuid())
  coachId   String
  plan      SubscriptionPlan?
  status    SubscriptionStatus
  startsAt  DateTime           @default(now())
  endsAt    DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  coach    CoachProfile @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  payments Payment[]

  @@index([coachId, status])
}

model Payment {
  id             String         @id @default(cuid())
  coachId        String
  subscriptionId String?
  gateway        PaymentGateway
  plan           SubscriptionPlan
  amount         Int // minor units (Rial / cents)
  currency       String // "IRR" | "USD" ...
  status         PaymentStatus  @default(PENDING)
  reference      String? // gateway authority / session id (idempotency key)
  raw            Json? // gateway payload for audit
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  coach        CoachProfile  @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([gateway, reference])
  @@index([coachId])
}

// ── Program requests (public-page intake) ────────────────────────────────────
model ProgramRequest {
  id               String               @id @default(cuid())
  coachId          String
  studentUserId    String // the logged-in student who submitted
  studentProfileId String? // the coach's StudentProfile this links to (find-or-create)
  fullName         String
  phone            String?
  age              Int?
  weightKg         Float?
  heightCm         Float?
  trainingYears    Int? // training history — years
  trainingMonths   Int? // training history — months
  medicalHistory   String? // illness / injury notes
  daysPerWeek      Int?
  // private object keys (bucket: requests)
  photoFrontKey    String?
  photoSideKey     String?
  photoBackKey     String?
  receiptKey       String? // payment receipt
  status           ProgramRequestStatus @default(PENDING)
  declineReason    String? // set when the coach declines
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  coach   CoachProfile @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  student User         @relation(fields: [studentUserId], references: [id], onDelete: Cascade)

  @@index([coachId, status])
  @@index([studentUserId])
}
